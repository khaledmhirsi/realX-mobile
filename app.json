{
  "expo": {
    "name": "realX",
    "slug": "reelx",
    "version": "1.1.4",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reelx",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reelx.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [],
      "infoPlist": {
        "EXDevMenuIsOnboardingFinished": true,
        "EXDevMenuShowFloatingActionButton": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "realX uses your location to show nearby vendors and discounts on the map."
      },
      "appleTeamId": "2396PCT42P"
    },
    "android": {
      "package": "com.reelx.app",
      "versionCode": 6,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAZzzmsBPiXDGSRF3HOGgWXXRQsEurm19I"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "intentFilters": [],
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "ar"
            ],
            "android": [
              "en",
              "ar"
            ]
          }
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sound.wav"]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow location access to show nearby vendors"
        }
      ],
      [
        "react-native-bottom-tabs"
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#18B852",
          "image": "./assets/images/splash.png"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Hanson-Bold.otf",
            "./assets/fonts/poppins.ttf",
            "./assets/fonts/jali-arabic-regular.ttf",
            "./assets/fonts/jali-arabic-bold.ttf",
            "./assets/fonts/Tajawal-Black.ttf"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      "./plugins/with-rnfb-app-check-ios-fix",
      "@react-native-firebase/auth",
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supportRTl": true,
      "router": {},
      "eas": {
        "projectId": "462a3cda-e70c-4472-8637-8794ff697f77"
      }
    }
  }
}
